# PostgreSQL
DATABASE_URL=postgresql+asyncpg://docforge:docforge@localhost:5432/docforge

# Redis
REDIS_URL=redis://localhost:6380/0

# MinIO
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=docforge
MINIO_SECRET_KEY=docforge123
MINIO_BUCKET=docforge
MINIO_USE_SSL=false

# JWT
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=60

# LLM Provider (openai, anthropic, ollama, deepseek).
# Default is ollama for a fully-local, no-API-key setup (the project's goal).
LLM_PROVIDER=ollama
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
ANTHROPIC_BASE_URL=https://api.anthropic.com/v1
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022
# Per Docker: usare http://host.docker.internal:11434/v1
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=llama3
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat

# Embeddings (RAG). EMBEDDING_DIMENSION MUST match the pgvector column, which is
# vector(768) (migration 022). Default = local ollama nomic-embed-text (768).
# To use OpenAI (text-embedding-3-small=1536) you must also migrate the column
# back to vector(1536) and reindex (POST /sources/reindex-all).
EMBEDDING_PROVIDER=ollama
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_DIMENSION=768

# Two-phase drafting: distil style/structure notes from the corpus before each
# section is written (facts still come only from the brief). false = pure
# brief-driven drafting.
DRAFT_EXTRACTION_ENABLED=true

# Logging
LOG_LEVEL=INFO
