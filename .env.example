# PostgreSQL
DATABASE_URL=postgresql+asyncpg://docforge:docforge@localhost:5432/docforge

# Redis
REDIS_URL=redis://localhost:6379/0

# MinIO
STORAGE_PROVIDER=minio
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=docforge
MINIO_SECRET_KEY=docforge123
MINIO_BUCKET=docforge
MINIO_USE_SSL=false

# JWT
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=60

# LLM Provider (openai, anthropic, ollama, deepseek)
LLM_PROVIDER=openai
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
ANTHROPIC_BASE_URL=https://api.anthropic.com/v1
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022
# Per Docker: usare http://host.docker.internal:11434/v1
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=llama3
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat

# Observability
OTEL_SERVICE_NAME=docforge
ENABLE_OTEL=false
LOG_LEVEL=INFO
