# PostgreSQL
DATABASE_URL=postgresql+asyncpg://docforge:docforge@localhost:5432/docforge
POSTGRES_USER=docforge
POSTGRES_PASSWORD=docforge
POSTGRES_DB=docforge

# Redis
REDIS_URL=redis://localhost:6379/0

# MinIO
STORAGE_PROVIDER=minio
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=docforge
MINIO_SECRET_KEY=docforge123
MINIO_BUCKET=docforge
MINIO_USE_SSL=false

# JWT
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=60

# LLM Providers
LLM_PROVIDER=openai
LLM_DEFAULT_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
OPENAI_DEFAULT_MODEL=gpt-4o
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514
ANTHROPIC_DEFAULT_MODEL=claude-sonnet-4-20250514

# OCR
OCR_DEFAULT_ENGINE=tesseract

# Celery
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Frontend
VITE_API_BASE_URL=http://localhost:8000/api/v1
VITE_WS_URL=ws://localhost:8000/ws

# Observability
OTEL_SERVICE_NAME=docforge
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
ENABLE_OTEL=false
LOG_LEVEL=INFO
